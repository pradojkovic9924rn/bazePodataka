TYPE=TRIGGERS
triggers='CREATE DEFINER=`root`@`localhost` TRIGGER proveri_vreme_sesije_pre_insert\nBEFORE INSERT ON sesija\nFOR EACH ROW\nBEGIN\n    IF NEW.vreme_zavrsetka <= NEW.vreme_pocetka THEN\n        SIGNAL SQLSTATE \'45000\'\n        SET MESSAGE_TEXT = \'Vreme zavrsetka mora biti posle vremena pocetka.\';\n    END IF;\nEND' 'CREATE DEFINER=`root`@`localhost` TRIGGER proveri_preklapanje_sesija_pre_insert\nBEFORE INSERT ON sesija\nFOR EACH ROW\nBEGIN\n    DECLARE nova_laboratorija_id INT;\n    DECLARE broj_preklapanja INT;\n\n    SELECT laboratorija_id\n    INTO nova_laboratorija_id\n    FROM izvodjenje\n    WHERE izvodjenje_id = NEW.izvodjenje_id;\n\n    SELECT COUNT(*)\n    INTO broj_preklapanja\n    FROM sesija s\n    JOIN izvodjenje i ON s.izvodjenje_id = i.izvodjenje_id\n    WHERE i.laboratorija_id = nova_laboratorija_id\n      AND s.datum = NEW.datum\n      AND NEW.vreme_pocetka < s.vreme_zavrsetka\n      AND NEW.vreme_zavrsetka > s.vreme_pocetka;\n\n    IF broj_preklapanja > 0 THEN\n        SIGNAL SQLSTATE \'45000\'\n        SET MESSAGE_TEXT = \'Sesija se vremenski preklapa sa drugom sesijom u istoj laboratoriji.\';\n    END IF;\nEND' 'CREATE DEFINER=`root`@`localhost` TRIGGER proveri_vreme_sesije_pre_update\nBEFORE UPDATE ON sesija\nFOR EACH ROW\nBEGIN\n    IF NEW.vreme_zavrsetka <= NEW.vreme_pocetka THEN\n        SIGNAL SQLSTATE \'45000\'\n        SET MESSAGE_TEXT = \'Vreme zavrsetka mora biti posle vremena pocetka.\';\n    END IF;\nEND' 'CREATE DEFINER=`root`@`localhost` TRIGGER proveri_preklapanje_sesija_pre_update\nBEFORE UPDATE ON sesija\nFOR EACH ROW\nBEGIN\n    DECLARE nova_laboratorija_id INT;\n    DECLARE broj_preklapanja INT;\n\n    SELECT laboratorija_id\n    INTO nova_laboratorija_id\n    FROM izvodjenje\n    WHERE izvodjenje_id = NEW.izvodjenje_id;\n\n    SELECT COUNT(*)\n    INTO broj_preklapanja\n    FROM sesija s\n    JOIN izvodjenje i ON s.izvodjenje_id = i.izvodjenje_id\n    WHERE i.laboratorija_id = nova_laboratorija_id\n      AND s.datum = NEW.datum\n      AND s.sesija_id <> NEW.sesija_id\n      AND NEW.vreme_pocetka < s.vreme_zavrsetka\n      AND NEW.vreme_zavrsetka > s.vreme_pocetka;\n\n    IF broj_preklapanja > 0 THEN\n        SIGNAL SQLSTATE \'45000\'\n        SET MESSAGE_TEXT = \'Sesija se vremenski preklapa sa drugom sesijom u istoj laboratoriji.\';\n    END IF;\nEND'
